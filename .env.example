# Servidor
PORT=8080
ENV=development    # development | production

# Banco de dados
DATABASE_URL=postgres://ecoinventario:ecoinventario_dev@localhost:5434/ecoinventario?sslmode=disable
PASSWORD_PEPPER=troque_esta_chave_em_producao   # obrigatório — nunca deixar vazio em prod

# JWT Ed25519 (gerar: openssl genpkey -algorithm Ed25519)
JWT_PRIVATE_KEY=base64_da_chave_privada
JWT_PUBLIC_KEY=base64_da_chave_publica
JWT_ACCESS_EXPIRY=15m       # opcional, padrão 15m
JWT_REFRESH_EXPIRY=720h     # opcional, padrão 30d

# ─── Cloudflare R2 (Storage de fotos) ────────────────────────────────────────
# Bucket: ecoinventario-fotos
# Painel: dash.cloudflare.com → R2 Object Storage → Manage R2 API Tokens
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY=seu_access_key_id_do_r2
S3_SECRET_KEY=seu_secret_access_key_do_r2
S3_BUCKET=ecoinventario-fotos
S3_REGION=auto
S3_USE_PATH_STYLE=true
# Preencher após ativar Public Access no bucket R2 (formato: https://pub-xxx.r2.dev)
S3_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# CORS (lista separada por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://seudominio.com.br
